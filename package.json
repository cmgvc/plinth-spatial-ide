{
  "name": "plinth",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev:client": "npm run dev --workspace=apps/client",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev": "concurrently -n \"CLIENT,SERVER\" -c \"cyan,magenta\" \"npm run dev:client\" \"npm run dev:server\"",
    "test": "npm run test -w apps/client",
    "test:e2e": "playwright test -c apps/client/playwright.config.ts",
    "test:ui": "playwright test -c apps/client/playwright.config.ts --ui",
    "build": "npm run build --workspaces --if-present"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
  "react": "^19.0.0",
  "react-dom": "^19.0.0"
}
}
